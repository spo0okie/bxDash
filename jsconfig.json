{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"baseUrl": ".",
		"paths": {
			"Components/*": ["src/Components/*"],
			"Data/*": ["src/Data/*"],
			"Data/Models/*": ["src/Data/Models/*"],
			"Helpers/*": ["src/Helpers/*"],
			"config": ["src/config.priv.js"]
		},
		"experimentalDecorators": true,
		"jsx": "react-jsx"
	},
	"include": ["src"]
}
